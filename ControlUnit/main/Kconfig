    menu "Pump Controller Configuration"
        config PUMP_MONITORING_TICK_PERIOD_MS
            int "Pump Monitoring Tick Period (milliseconds)"
            range 10000 300000
            default 60000
            help
                Period for pump monitoring timer ticks in milliseconds.
                
        config PUMP_STALL_CHECK_INTERVAL_MS
            int "Pump Stall Check Interval (milliseconds)"
            range 5000 60000
            default 10000
            help
                Interval for checking pump stall condition in milliseconds.
                
        config PUMP_DEFAULT_MANUAL_LOCKOUT_DURATION_MS
            int "Default Manual Lockout Duration (milliseconds)"
            range 300000 28800000
            default 7200000
            help
                Default duration for manual pump lockout in milliseconds (2 hours default).
                
        config PUMP_MIN_WATER_LEVEL_TO_START
            int "Minimum Water Level to Start Pump (%)"
            range 0 100
            default 15
            help
                Minimum water level percentage required to start the pump automatically.
                
        config PUMP_MAX_WATER_LEVEL_TO_STOP
            int "Maximum Water Level to Stop Pump (%)"
            range 0 100
            default 85
            help
                Maximum water level percentage at which to stop the pump automatically.

        config PUMP_IMMEDIATE_STALL_CHECK_INTERVAL_MS
            int "Immediate Stall Check Interval (ms)"
            range 5000 30000
            default 15000
            help
                Interval for the fast 'no fill' trend check in milliseconds. This should be shorter than the main stall check.

        config PUMP_STALL_GRACE_PERIOD_SEC
            int "Stall Detection Grace Period (seconds)"
            range 10 300
            default 60
            help
                A grace period at the start of a pump cycle (if starting at 0% water level) where stall checks are paused to allow the water level to rise out of the sensor's dead zone.
    endmenu

    menu "WiFi Configuration"
        menu "Access Point Settings"
            
            config WIFI_USE_DYNAMIC_CREDENTIALS
                bool "Use Dynamic AP Credentials"
                default y
                help
                    Enable dynamic generation of WiFi AP SSID and password based on device MAC address.
                    When enabled, the AP will use a unique 30-character cryptic SSID and 32-character
                    password generated using HKDF-SHA256. This provides better security and uniqueness
                    per device. When disabled, static credentials from secrets.h will be used.
                    
            config WIFI_AP_CHANNEL
                int "WiFi Access Point Channel"
                range 1 13
                default 1
                help
                    WiFi channel for the Access Point.
                    
            config WIFI_AP_SSID_HIDDEN
                int "Hide Access Point SSID"
                range 0 1
                default 0
                help
                    Whether to make the AP visible to nearby devices.
                    0 - visible, 1 - invisible
                    
            config WIFI_AP_MAX_CONNECTIONS
                int "Maximum AP Connections"
                range 1 10
                default 1
                help
                    Maximum number of devices that can connect to this Access Point.
                    
            config WIFI_AP_BEACON_INTERVAL
                int "AP Beacon Interval (milliseconds)"
                range 100 1000
                default 300
                help
                    Access Point beacon interval in milliseconds.
                    100 recommended for normal operation.
                    
            config WIFI_AP_IP
                string "Access Point IP Address"
                default "192.168.4.1"
                help
                    Default IP Address for the Access Point.
                    
            config WIFI_AP_GATEWAY
                string "Access Point Gateway"
                default "192.168.4.1"
                help
                    Default Gateway (should be the same as the IP Address).
                    
            config WIFI_AP_NETMASK
                string "Access Point Netmask"
                default "255.255.255.0"
                help
                    Access Point network mask.
        endmenu
        
        menu "Station Mode Settings"
