menu "WPSwitch Receiver Configuration"

    choice BOARD_VARIANT
        prompt "Board Variant"
        default BOARD_VARIANT_PROTOTYPE
        help
            Select the hardware revision of the receiver board.

        config BOARD_VARIANT_PROTOTYPE
            bool "Prototype Edition"
        config BOARD_VARIANT_REV1
            bool "Revision 1 (Production)"
    endchoice

    menu "GPIO Pin Configuration"
        
        menu "Relay Control Pins"
            config MOTOR_RELAY_SET_PIN
                int "Motor Relay Set Pin"
                range 0 39
                default 26
                help
                    GPIO pin number for setting the motor relay to ON state.
                    
            config MOTOR_RELAY_RESET_PIN
                int "Motor Relay Reset Pin"
                range 0 39
                default 25
                help
                    GPIO pin number for resetting the motor relay to OFF state.
                    
            config MOTOR_RELAY_STATE_INPUT_PIN
                int "Motor Relay State Input Pin"
                range 0 39
                default 13
                help
                    GPIO pin number for reading the current state of the motor relay.

            config LINE_FEEDBACK_PIN
                int "Line Feedback Input Pin"
                depends on BOARD_VARIANT_REV1
                range 0 39
                default 35
                help
                    GPIO pin number for line feedback monitoring.
                    Note: GPIO35 is input-only on ESP32.
        endmenu
        
        menu "Button and LED Pins"
            config MOTOR_TOGGLE_BUTTON_INPUT_PIN
                int "Motor Toggle Button Input Pin"
                range 0 39
                default 21
                help
                    GPIO pin number for the motor toggle button input.
                    
            config MOTOR_TOGGLE_BUTTON_LED_OUTPUT_PIN
                int "Motor Toggle Button LED Output Pin"
                range 0 39
                default 19
                help
                    GPIO pin number for the motor toggle button LED indicator.
                    
            config NEOPIXEL_DATA_OUTPUT_PIN
                int "NeoPixel Data Output Pin"
                range 0 39
                default 23
                help
                    GPIO pin number for NeoPixel LED strip data output.
                    
            config LED_BUILTIN
                int "Built-in LED Pin"
                range 0 39
                default 2
                help
                    GPIO pin number for the built-in LED.
                    
            config CONFIG_MODE_BUTTON_INPUT
                int "Configuration Mode Button Input Pin"
                range 32 39
                default 34
                help
                    GPIO pin number for the configuration mode button.
                    Note: GPIO34 is input-only on ESP32.
                    
            config BUZZER_OUTPUT_PIN
                int "Buzzer Output Pin"
                range 0 39
                default 33
                help
                    GPIO pin number for the buzzer.
                    Note: GPIO33 is input-only on ESP32, this is a known issue in the Prototype.
        endmenu
        
        menu "Display Pins"
            config CLOCK_PIN
                int "Display Clock Pin"
                range 0 39
                default 5
                help
                    GPIO pin number for the display clock signal.
                    
            config LATCH_PIN
                int "Display Latch Pin"
                range 0 39
                default 22
                help
                    GPIO pin number for the display latch signal.
                    
            config DATA_PIN
                int "Display Data Pin"
                range 0 39
                default 18
                help
                    GPIO pin number for the display data signal.
        endmenu
        
        menu "Wireless Communication Pins"
            config WIRELESS_DATA_RX_PIN
                int "Wireless Data RX Pin"
                range 0 39
                default 16
                help
                    GPIO pin number for wireless module data reception.
                    
            config WIRELESS_DATA_TX_PIN
                int "Wireless Data TX Pin"
                range 0 39
                default 17
                help
                    GPIO pin number for wireless module data transmission.
                    
            config WIRELESS_PRG_MODE_PIN
                int "Wireless Programming Mode Pin"
                range 0 39
                default 4
                help
                    GPIO pin number for wireless module programming mode control.
        endmenu
        
        menu "UART Pins"
            config HC_05_TX_PIN
                int "HC-05 TX Pin"
                range 0 39
                default 1
                help
                    GPIO pin number for HC-05 Bluetooth module TX.
                    
            config HC_05_RX_PIN
                int "HC-05 RX Pin"
                range 0 39
                default 3
                help
                    GPIO pin number for HC-05 Bluetooth module RX.
        endmenu
        
        menu "I2C Pins"
            config DS1307_SDA_PIN
                int "DS1307 RTC SDA Pin"
                range 0 39
                default 32
                help
                    GPIO pin number for DS1307 RTC I2C SDA line.
                    
            config DS1307_SCL_PIN
                int "DS1307 RTC SCL Pin"
                range 0 39
                default 27
                help
                    GPIO pin number for DS1307 RTC I2C SCL line.
        endmenu    
    endmenu

    menu "UART Configuration"
        config UART_PORT_FOR_RECEIVER
            int "UART Port Number for Receiver"
            range 0 2
            default 2
            help
                UART port number used for receiver communication.
                ESP32 has UART0, UART1, and UART2 available.
                
        config RECEIVER_PORT_UART_BAUD_RATE
            int "Receiver Port UART Baud Rate"
            default 9600
            help
                Baud rate for UART communication with the receiver module.
                Common values: 9600, 19200, 38400, 57600, 115200
                
        config UART_BUFFER_SIZE
            int "UART Buffer Size"
            range 256 4096
            default 1024
            help
                Size of the UART receive/transmit buffer in bytes.
                
        config UART_DATA_RECEPTION_TIMEOUT_SEC
            int "UART Data Reception Timeout (seconds)"
            range 1 300
            default 10
            help
                Timeout in seconds for UART data reception.
                After this timeout, a data reception timeout event will be triggered.
    endmenu

    menu "Sensor Configuration"
        config MIN_HUMIDITY_LEVEL
            int "Minimum Humidity Level"
            range 0 100
            default 15
            help
                Minimum acceptable humidity level in percentage.
                
        config MAX_HUMIDITY_LEVEL
            int "Maximum Humidity Level"
            range 0 100
            default 85
            help
                Maximum acceptable humidity level in percentage.
                
        config MIN_TEMPERATURE_LEVEL
            int "Minimum Temperature Level"
            range -40 85
            default 0
            help
                Minimum acceptable temperature level in Celsius.
                
        config MAX_TEMPERATURE_LEVEL
            int "Maximum Temperature Level"
            range -40 85
            default 55
            help
                Maximum acceptable temperature level in Celsius.
                
        config MIN_WATER_LEVEL
            int "Minimum Water Level"
            range 0 100
            default 0
            help
                Minimum water level in percentage.
                
        config MAX_WATER_LEVEL
            int "Maximum Water Level"
            range 0 100
            default 100
            help
                Maximum water level in percentage.
    endmenu

    menu "MQTT Configuration"
        config MQTT_BROKER_URL
            string "MQTT Broker URL (Production)"
            default "mqtts://k01b8b84.ala.asia-southeast1.emqxsl.com"
            help
                URL of the MQTT broker to connect to for production.
                Use mqtts:// for TLS secured connections or mqtt:// for unsecured.
                
        config MQTT_BROKER_PORT
            int "MQTT Broker Port (Production)"
            range 1 65535
            default 8883
            help
                Port number for MQTT broker connection for production.
                Common values: 8883 (TLS), 1883 (unsecured), 8084 (WebSocket with TLS)
                
        config MQTT_BROKER_URL_DEV
            string "MQTT Broker URL (Development)"
            default "mqtt://192.168.1.107:1883"
            help
                URL of the MQTT broker to connect to for development.
                Use mqtts:// for TLS secured connections or mqtt:// for unsecured.
                
        config MQTT_BROKER_PORT_DEV
            int "MQTT Broker Port (Development)"
            range 1 65535
            default 1883
            help
                Port number for MQTT broker connection for development.
                Common values: 8883 (TLS), 1883 (unsecured), 8084 (WebSocket with TLS)
                

                
        config MQTT_KEEP_ALIVE_INTERVAL_SECONDS
            int "MQTT Keep Alive Interval (seconds)"
            range 1 300
            default 30
            help
                Keep alive interval for MQTT connection in seconds.
                
        config MQTT_RECONNECT_TIMER_PERIOD_MS
            int "MQTT Reconnect Timer Period (milliseconds)"
            range 1000 60000
            default 10000
            help
                Period for MQTT reconnection attempts in milliseconds.
                
        config MQTT_NETWORK_TIMEOUT_MS
            int "MQTT Network Operation Timeout (milliseconds)"
            range 10000 120000
            default 30000
            help
                Timeout for MQTT network operations including TLS handshake.
                Increase this value for unreliable internet connections.
                Default ESP-IDF value is 10000ms which is too short for
                TLS connections over the internet. Recommended: 30000ms.
                
        config MQTT_MAX_TOPIC_LENGTH
            int "Maximum MQTT Topic Length"
            range 20 100
            default 45
            help
                Maximum allowed length for MQTT topic strings.
                
        config MQTT_SESSION_EXPIRY_INTERVAL
            int "MQTT Session Expiry Interval"
            range 1 3600
            default 10
            help
                MQTT 5 session expiry interval in seconds.
                
        config MQTT_MAXIMUM_PACKET_SIZE
            int "MQTT Maximum Packet Size"
            range 256 8192
            default 1024
            help
                Maximum MQTT packet size in bytes.
                
        config MQTT_MESSAGE_EXPIRY_INTERVAL
            int "MQTT Message Expiry Interval"
            range 1 300
            default 10
            help
                MQTT 5 message expiry interval in seconds.
                
        config MQTT_WILL_DELAY_INTERVAL
            int "MQTT Will Delay Interval"
            range 1 300
            default 10
            help
                MQTT 5 will delay interval in seconds.
                
        config MQTT_INPUT_BUFFER_SIZE
            int "MQTT Input Buffer Size"
            range 512 8192
            default 2048
            help
                Size of MQTT input buffer in bytes.
                
        config MQTT_OUTPUT_BUFFER_SIZE
            int "MQTT Output Buffer Size"
            range 512 8192
            default 2048
            help
                Size of MQTT output buffer in bytes.
                
        config MQTT_MESSAGE_RETRANSMISSION_PERIOD
            int "MQTT Message Retransmission Period (milliseconds)"
            range 1000 30000
            default 5000
            help
                Period for MQTT message retransmission in milliseconds.
                
        config MQTT_TASK_STACK_DEPTH
            int "MQTT Task Stack Depth"
            range 4096 16384
            default 8192
            help
                Stack depth for MQTT task in bytes.
                
        config WPSWITCH_MQTT_TASK_PRIORITY
            int "MQTT Task Priority"
            range 1 25
            default 12
            help
                Priority level for MQTT task.
    endmenu

