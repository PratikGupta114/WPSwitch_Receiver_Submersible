                string "Primary SNTP Server"
                default "pool.ntp.org"
                help
                    Primary NTP server for time synchronization.
                    
            config SNTP_SERVER_NAME_1
                string "Secondary SNTP Server"
                default "in.pool.ntp.org"
                help
                    Secondary NTP server for time synchronization.
                    
            config SNTP_TIME_SYNC_TASK_STACK_DEPTH
                int "SNTP Task Stack Depth"
                range 2048 8192
                default 2560
                help
                    Stack depth for SNTP time synchronization task.
                    Optimized from 4096 to 2560 bytes based on measured high water marks.
                    
            config SNTP_TIME_SYNC_TASK_PRIORITY
                int "SNTP Task Priority"
                range 1 25
                default 25
                help
                    Priority level for SNTP time synchronization task.
                    
            config SNTP_TIME_SYNC_INTERVAL
                int "SNTP Sync Interval (milliseconds)"
                range 60000 3600000
                default 195000
                help
                    Interval between SNTP synchronization attempts in milliseconds.
                    Default is 3 minutes 15 seconds (195000 ms).
                    
            config SNTP_TIME_SYNC_RETRY_INTERVAL
                int "SNTP Sync Retry Interval (milliseconds)"
                range 1000 30000
                default 3000
                help
                    Interval between SNTP retry attempts in milliseconds.
                    
            config SNTP_SYNC_RETRY_COUNT
                int "SNTP Sync Retry Count"
                range 1 100
                default 50
                help
                    Maximum number of SNTP synchronization retry attempts.
        endmenu
        
        menu "WiFi Task Configuration"
            config WIFI_RECONNECTION_TASK_STACK_DEPTH
                int "WiFi Reconnection Task Stack Depth"
                range 2048 8192
                default 2560
                help
                    Stack depth for WiFi reconnection task.
                    Optimized from 4096 to 2560 bytes based on measured high water marks.
                    
            config WIFI_RECONNECTION_TASK_PRIORITY
